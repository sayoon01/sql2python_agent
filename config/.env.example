# ── 앱 ────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Ollama (로컬 LLM) ─────────────────────────────────────
# 설치: https://ollama.ai
# 모델:
