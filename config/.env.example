# ── 앱 ────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ── DB 전환 스위치 ─────────────────────────────────────────
#   mssql      → SQL Server  (pyodbc)
#   postgresql → PostgreSQL  (psycopg2)
DB_MODE=mssql

# ── SQL Server ────────────────────────────────────────────
MSSQL_SERVER=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=mydb
MSSQL_USERNAME=sa
MSSQL_PASSWORD=your_password
MSSQL_DRIVER=ODBC Driver 17 for SQL Server

# ── PostgreSQL ────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=mydb
PG_USER=postgres
PG_PASSWORD=your_password

# ── LLM ──────────────────────────────────────────────────
# ── Ollama (로컬 LLM) ─────────────────────────────────────
# 설치: https://ollama.ai
# 모델: ollama pull glm-4.7-flash:Q4_K_M && ollama pull gemma3:27b && ollama pull qwen2.5-coder:32b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_KEEP_ALIVE=10m
